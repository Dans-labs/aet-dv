, "score": 0.687}, {"word": "zou", "start": 38.568, "end": 38.768, "score": 0.651}, {"word": "gaan", "start": 38.788, "end": 38.928, "score": 0.757}, {"word": "doen.", "start": 38.968, "end": 39.269, "score": 0.991}]}, {"start": 39.289, "end": 39.99, "text": "Geweldig.", "words": [{"word": "Geweldig.", "start": 39.289, "end": 39.99, "score": 0.505}]}, {"start": 40.01, "end": 43.977, "text": "Je moest in een voorstel aangeven, maximaal vier pagina's of zo.", "words": [{"word": "Je", "start": 40.01, "end": 40.231, "score": 0.686}, {"word": "moest", "start": 40.251, "end": 40.351, "score": 0.757}, {"word": "in", "start": 40.391, "end": 40.431, "score": 0.982}, {"word": "een", "start": 40.451, "end": 40.551, "score": 0.823}, {"word": "voorstel", "start": 40.591, "end": 41.012, "score": 0.986}, {"word": "aangeven,", "start": 41.313, "end": 42.294, "score": 0.905}, {"word": "maximaal", "start": 42.314, "end": 42.875, "score": 0.883}, {"word": "vier", "start": 42.895, "end": 43.176, "score": 0.74}, {"word": "pagina's", "start": 43.196, "end": 43.717, "score": 0.246}, {"word": "of", "start": 43.737, "end": 43.857, "score": 0.655}, {"word": "zo.", "start": 43.877, "end": 43.977, "score": 0.295}]}, {"start": 43.997, "end": 46.221, "text": "Het stond er wel heel duidelijk in, die oproep.", "words": [{"word": "Het", "start": 43.997, "end": 44.057, "score": 0.108}, {"word": "stond", "start": 44.077, "end": 44.177, "score": 0.367}, {"word": "er", "start": 44.218, "end": 44.258, "score": 0.54}, {"word": "wel", "start": 44.278, "end": 44.358, "score": 0.953}, {"word": "heel", "start": 44.378, "end": 44.498, "score": 0.902}, {"word": "duidelijk", "start": 44.558, "end": 44.879, "score": 0.925}, {"word": "in,", "start": 44.919, "end": 45.059, "score": 0.938}, {"word": "die", "start": 45.079, "end": 45.259, "score": 0.839}, {"word": "oproep.", "start": 45.319, "end": 46.221, "score": 0.85}]}, {"start": 46.201, "end": 49.67, "text": " En ik heb daarna toen...", "words": [{"word": "En",